# GLM 5.1 FP8 Stack — Environment Variables
# Copy to .env: cp .env.example .env

# HuggingFace token — not needed, GLM 5.1 is public
HF_TOKEN=

# LiteLLM gateway master key
# Generate: echo "sk-$(openssl rand -hex 16)"
LITELLM_MASTER_KEY=sk-change-me-123

# Open WebUI session secret
# Generate: openssl rand -hex 24
WEBUI_SECRET_KEY=change-me-webui-secret
